# Copy to .env and adjust. Loaded automatically at startup (Node built-in).
# All values are optional; unset means "use the default".

# HTTP server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Login (username/password). Login is enabled BY DEFAULT with the credentials
# below (admin/admin) so a freshly unpacked instance isn't open to anyone who
# reaches its port. These are well-known weak values — CHANGE THEM before
# exposing the server, otherwise the panel is effectively unprotected.
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Optional static bearer token (alternative/legacy auth, accepted alongside login).
# AUTH_TOKEN=

# CORS origin for the API (default "*").
# CORS_ORIGIN=https://squash.example.com

# Override the served frontend directory (auto-derived next to the app otherwise).
# SQUASH_STATIC_DIR=/app/frontend/dist
