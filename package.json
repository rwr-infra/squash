{
  "name": "squash-rwr-terminal-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.build.json",
    "build:web": "npm --prefix frontend ci && npm --prefix frontend run build",
    "bundle:server": "node scripts/bundle-server.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "package:exe": "npm run build:web && npm run bundle:server && pkg dist-bin/server.cjs --config package.json --targets host --output dist-bin/squash",
    "smoke:pty": "tsx scripts/pty-rwr-smoke.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "pkg": {
    "assets": [
      "node_modules/node-pty/prebuilds/**/*",
      "node_modules/node-pty/lib/**/*",
      "node_modules/node-pty/package.json",
      "frontend/dist/**/*"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.4",
    "node-pty": "^1.2.0-beta.12",
    "pino": "10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@yao-pkg/pkg": "^6.20.0",
    "esbuild": "^0.28.1",
    "patch-package": "^8.0.1",
    "pino-pretty": "^13.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
